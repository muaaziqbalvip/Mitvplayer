<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows cleartext HTTP traffic for IPTV stream URLs.
    Many IPTV providers serve streams over HTTP (not HTTPS).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
